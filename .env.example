# Database Configuration (MSSQL)
DB_SERVER=localhost
DB_NAME=competency_matrix
DB_USER=sa
DB_PASSWORD=sa-password
DB_ENCRYPT=false

# Jira Configuration
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_BOARDS=board1,board2,board3

# Confluence Configuration
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_USERNAME=your-email@company.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_SPACES=space1,space2,space3

# Bitbucket Configuration
BITBUCKET_URL=https://api.bitbucket.org/2.0
BITBUCKET_USERNAME=your-bitbucket-username
BITBUCKET_APP_PASSWORD=your-bitbucket-app-password
BITBUCKET_WORKSPACES=workspace1,workspace2
BITBUCKET_REPOS=team-repo1,team-repo2,team-repo3

# Artifact Storage
ARTIFACT_STORE_TYPE=local
LOCAL_ARTIFACT_PATH=./artifacts

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# API Configuration
API_PORT=3000
API_HOST=localhost

# JWT Secret (for authentication)
JWT_SECRET=your_jwt_secret_here
