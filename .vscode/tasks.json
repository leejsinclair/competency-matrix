{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "1.1: Rule Engine Tests",
      "detail": "Test rule-based labeling system for CircleCI competency matrix",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "./scripts/with-nvm.sh npm test -- tests/processing/rule-engine.test.ts"
      ],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [
        {
          "owner": "jest",
          "fileLocation": [
            "relative",
            "${workspaceFolder}"
          ],
          "pattern": [
            {
              "regexp": "^\\s+at\\s+.*\\((.*):(\\d+):(\\d+)\\)$",
              "file": 1,
              "line": 2,
              "column": 3
            }
          ]
        }
      ]
    },
